kw_result <- kruskal.test(S1E ~ purpose, data = QQ)
print(kw_result)
# 2. 如果 kw_result 的 p < 0.05，進行事後檢定 (Dunn Test)
# 請確認已經安裝 dunn.test 套件
library(dunn.test)
dunn.test(QQ$S1E, QQ$purpose, method="bonferroni")
shapiro.test(QQ$S1E)
kw_result <- kruskal.test(S1E ~ purpose, data = QQ)
print(kw_result)
