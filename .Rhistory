# =========================================================================
# 4.0 套件載入
# =========================================================================
library(ggplot2)
library(tidyverse)
library(dunn.test)
library(AER)
# =========================================================================
# 💡 終極大絕招：直接在 R 裡面強制產生純英文的組別代號（完全不管原本的中文！）
# =========================================================================
QQ$grp <- factor(rep(c("School", "Shop", "Clinic", "Tour", "USR"), each = 20),
levels = c("School", "Shop", "Clinic", "Tour", "USR"))
# =========================================================================
# 【圖 4-1】第一階段營運效率（S1E）分佈箱形圖
# =========================================================================
p1 <- ggplot(QQ, aes(x = grp, y = S1E, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
labs(title = "Stage 1 Efficiency (S1E) Distribution", x = "Purpose", y = "S1E Score") +
theme(legend.position = "none")
print(p1)
# =========================================================================
# 【圖 4-2】第二階段社會福祉效率（S2E）分佈箱形圖
# =========================================================================
p2 <- ggplot(QQ, aes(x = grp, y = S2E, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
labs(title = "Stage 2 Efficiency (S2E) Distribution", x = "Purpose", y = "S2E Score") +
theme(legend.position = "none")
print(p2)
# =========================================================================
# 【圖 4-3】最終完全體效率（FE）分佈箱形圖
# =========================================================================
p3 <- ggplot(QQ, aes(x = grp, y = FE, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
labs(title = "Final Efficiency (FE) Distribution", x = "Purpose", y = "FE Score") +
theme(legend.position = "none")
print(p3)
# =========================================================================
# 4.1 類別差異無母數檢定（Kruskal-Wallis + Dunn's Test）
# =========================================================================
cat("\n=== [Test A] Stage 1 Efficiency (S1E) Kruskal-Wallis ===\n")
print(kruskal.test(S1E ~ grp, data = QQ))
dunn.test(QQ$S1E, QQ$grp, method="bonferroni")
cat("\n=== [Test B] Stage 2 Efficiency (S2E) Kruskal-Wallis ===\n")
print(kruskal.test(S2E ~ grp, data = QQ))
dunn.test(QQ$S2E, QQ$grp, method="bonferroni")
cat("\n=== [Test C] Final Efficiency (FE) Kruskal-Wallis ===\n")
print(kruskal.test(FE ~ grp, data = QQ))
dunn.test(QQ$FE, QQ$grp, method="bonferroni")
# =========================================================================
# 4.2 第二階段社會福祉效率之 Tobit 影響因素迴歸分析
# =========================================================================
cat("\n=== [Tobit Regression] Y=S2E, X=MOAE+S1IAE ===\n")
tobit_model <- tobit(S2E ~ MOAE + S1IAE, left = 0, right = 1, data = QQ)
summary(tobit_model)
# =========================================================================
# 4.0 套件載入
# =========================================================================
library(ggplot2)
library(tidyverse)
library(dunn.test)
library(AER)
# 1. 建立純英文組別（確保後台運算不當機）
QQ$grp <- factor(rep(c("School", "Shop", "Clinic", "Tour", "USR"), each = 20),
levels = c("School", "Shop", "Clinic", "Tour", "USR"))
# 💡 2. 定義中文名稱對照表（讓圖表橫軸顯示完美的中文）
zh_labels <- c("School" = "就學", "Shop" = "購物", "Clinic" = "就醫", "Tour" = "觀光", "USR" = "USR活動")
# =========================================================================
# 【圖 4-1】第一階段營運效率（S1E）分佈箱形圖
# =========================================================================
p1 <- ggplot(QQ, aes(x = grp, y = S1E, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
scale_x_discrete(labels = zh_labels) + # 👈 強制把 X 軸換成中文標籤！
theme_minimal() +
labs(title = "圖 4-1：第一階段（營運效率 S1E）目的別分佈箱形圖", x = "搭乘目的", y = "第一階段效率分數") +
theme(
text = element_text(family = "Arial Unicode MS", size = 12), # 💡 確保 Windows/Mac 中文不亂碼
legend.position = "none",
plot.title = element_text(face = "bold", size = 13)
)
print(p1)
# =========================================================================
# 【圖 4-2】第二階段社會福祉效率（S2E）分佈箱形圖
# =========================================================================
p2 <- ggplot(QQ, aes(x = grp, y = S2E, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
scale_x_discrete(labels = zh_labels) + # 👈 強制把 X 軸換成中文標籤！
theme_minimal() +
labs(title = "圖 4-2：第二階段（社會福祉效率 S2E）目的別分佈箱形圖", x = "搭乘目的", y = "第二階段效率分數") +
theme(
text = element_text(family = "Arial Unicode MS", size = 12),
legend.position = "none",
plot.title = element_text(face = "bold", size = 13)
)
print(p2)
# =========================================================================
# 【圖 4-3】最終完全體效率（FE）分佈箱形圖
# =========================================================================
p3 <- ggplot(QQ, aes(x = grp, y = FE, fill = grp)) +
geom_boxplot(alpha = 0.6, outlier.shape = NA, width = 0.5) +
geom_jitter(width = 0.15, alpha = 0.7, size = 2, aes(color = grp)) +
scale_fill_brewer(palette = "Set1") +
scale_color_brewer(palette = "Set1") +
scale_x_discrete(labels = zh_labels) + # 👈 強制把 X 軸換成中文標籤！
theme_minimal() +
labs(title = "圖 4-3：最終完全體效率（FE）目的別分佈箱形圖", x = "搭乘目的", y = "最終綜合效率分數") +
theme(
text = element_text(family = "Arial Unicode MS", size = 12),
legend.position = "none",
plot.title = element_text(face = "bold", size = 13)
)
print(p3)
# =========================================================================
# 4.1 類別差異無母數檢定結果
# =========================================================================
cat("\n=== [檢定 A] 第一階段營運效率（S1E） Kruskal-Wallis ===\n")
print(kruskal.test(S1E ~ grp, data = QQ))
cat("\n=== [檢定 B] 第二階段社會福祉效率（S2E） Kruskal-Wallis ===\n")
print(kruskal.test(S2E ~ grp, data = QQ))
cat("\n=== [檢定 C] 最終完全體效率（FE） Kruskal-Wallis ===\n")
print(kruskal.test(FE ~ grp, data = QQ))
