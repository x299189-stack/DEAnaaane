# =========================================================================
# 4.0 套件載入與類別鎖定（100% 欄位名稱對齊版！）
# =========================================================================
library(tidyverse)
library(dunn.test)
library(AER) # Tobit 迴歸專用
# 強制將「目的」轉為因子（Factor），並死死鎖定五大類別順序
QQ <- QQ %>%
mutate(purpose = factor(`目的`, levels = c("就學", "購物", "就醫", "觀光", "USR活動")))
# =========================================================================
# 4.1 階段內橫向效率差異檢定（Kruskal-Wallis + Dunn's Test）
# =========================================================================
cat("\n========================================================\n")
cat("  [檢定 A] 第一階段營運效率之目的別 Kruskal-Wallis 檢定 \n")
cat("========================================================\n")
kw_div1 <- kruskal.test(`第一階段效率` ~ purpose, data = QQ)
print(kw_div1)
cat("\n--- 第一階段 Dunn's 事後兩兩比較 (Bonferroni 校正) ---\n")
dunn_div1 <- dunn.test(QQ$`第一階段效率`, QQ$purpose, method="bonferroni")
cat("\n========================================================\n")
cat("  [檢定 B] 第二階段社會福祉效率之目的別 Kruskal-Wallis 檢定 \n")
cat("========================================================\n")
kw_div2 <- kruskal.test(`第二階段效率` ~ purpose, data = QQ)
print(kw_div2)
cat("\n--- 第二階段 Dunn's 事後兩兩比較 (Bonferroni 校正) ---\n")
dunn_div2 <- dunn.test(QQ$`第二階段效率`, QQ$purpose, method="bonferroni")
cat("\n========================================================\n")
cat("  [檢定 C] 最終完全體效率之目的別 Kruskal-Wallis 檢定 \n")
cat("========================================================\n")
kw_final <- kruskal.test(`最終效率` ~ purpose, data = QQ)
print(kw_final)
cat("\n--- 最終完全體效率 Dunn's 事後兩兩比較 (Bonferroni 校正) ---\n")
dunn_final <- dunn.test(QQ$`最終效率`, QQ$purpose, method="bonferroni")
# =========================================================================
# 4.2 第二階段社會福祉效率之 Tobit 影響因素迴歸分析
# =========================================================================
cat("\n========================================================\n")
cat("  [Tobit 迴歸] 中間產出與第一階段投入對第二階段福祉效率之影響 \n")
cat("========================================================\n")
# Y = 第二階段效率
# X1 = `中間產出平均效率(%)`
# X2 = `第一階段投入平均效率(%)`
# 💡 欄位真名完全鎖定，包含圓括號與百分比符號！
tobit_model <- tobit(`第二階段效率` ~ `中間產出平均效率(%)` + `第一階段投入平均效率(%)`,
left = 0, right = 1, data = QQ)
summary(tobit_model)
