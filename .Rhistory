library(dplyr)
library(knitr)
library(kableExtra)
library(dunn.test)
# 1. 準備數據函數
get_dunn_table <- function(data, formula, label) {
test_res <- kruskal.test(formula, data = data)
dunn_res <- dunn.test(data[[all.vars(formula)[1]]], data[[all.vars(formula)[2]]],
method="bonferroni", list=TRUE)
# 整理成簡潔表格
df <- data.frame(
Comparison = dunn_res$comparisons,
Z_stat = dunn_res$Z,
P_adj = dunn_res$P.adjusted
) %>%
mutate(Sig = case_when(
P_adj < 0.001 ~ "***",
P_adj < 0.01 ~ "**",
P_adj < 0.05 ~ "*",
TRUE ~ "ns"
))
return(list(kw = test_res, dunn = df))
}
# 2. 執行分析
res_S1E <- get_dunn_table(QQ, S1E ~ grp_chinese, "第一階段")
library(dplyr)
library(knitr)
library(kableExtra)
library(dunn.test)
# --- 修復關鍵：確保 grp_chinese 存在 ---
# 直接從 purpose 欄位複製一份中文名稱作為分組依據
QQ$grp_chinese <- factor(QQ$purpose, levels = c("就學", "購物", "就醫", "觀光", "USR活動"))
# 1. 準備數據函數
get_dunn_table <- function(data, formula, label) {
test_res <- kruskal.test(formula, data = data)
# 這裡確保 dunn.test 使用正確的欄位
dunn_res <- dunn.test(data[[all.vars(formula)[1]]], data[[all.vars(formula)[2]]],
method="bonferroni", list=TRUE)
df <- data.frame(
Comparison = dunn_res$comparisons,
Z_stat = dunn_res$Z,
P_adj = dunn_res$P.adjusted
) %>%
mutate(Sig = case_when(
P_adj < 0.001 ~ "***",
P_adj < 0.01 ~ "**",
P_adj < 0.05 ~ "*",
TRUE ~ "ns"
))
return(list(kw = test_res, dunn = df))
}
# 2. 執行分析 (使用剛剛修復好的 grp_chinese)
res_S1E <- get_dunn_table(QQ, S1E ~ grp_chinese, "第一階段")
# 3. 輸出表格
res_S1E$dunn %>%
kable("html", caption = "表 4-X：第一階段營運效率事後兩兩比較 (Dunn's Test)",
col.names = c("組別比較", "Z 統計量", "校正後 P 值", "顯著性")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
library(dplyr)
library(knitr)
library(dunn.test)
# 1. 確保 grp_chinese 存在
QQ$grp_chinese <- factor(QQ$purpose, levels = c("就學", "購物", "就醫", "觀光", "USR活動"))
# 2. 準備數據函數
get_dunn_table <- function(data, formula) {
dunn_res <- dunn.test(data[[all.vars(formula)[1]]], data[[all.vars(formula)[2]]],
method="bonferroni", list=TRUE)
df <- data.frame(
Comparison = dunn_res$comparisons,
P_adj = round(dunn_res$P.adjusted, 4)
)
return(df)
}
# 3. 直接輸出簡潔版表格
res_S1E <- get_dunn_table(QQ, S1E ~ grp_chinese)
kable(res_S1E, caption = "表 4-X：第一階段營運效率事後兩兩比較 (Dunn's Test)")
shapiro.test(QQ$S1E)
kw_result <- kruskal.test(S1E ~ purpose, data = QQ)
print(kw_result)
library(dunn.test)
dunn.test(QQ$S1E, QQ$purpose, method="bonferroni")
kw_S2E <- kruskal.test(S2E ~ purpose, data = QQ)
print(kw_S2E)
dunn.test(QQ$S2E, QQ$purpose, method="bonferroni")
